<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report Subscriptions</title>
  <style>
    :root {
      --bg: #edf3f8;
      --surface: #ffffff;
      --ink: #142033;
      --muted: #5b6472;
      --line: #d7dee7;
      --brand: #0f172a;
      --accent: #0ea5a4;
      --good: #127a52;
      --warn: #9a3412;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(14,165,164,.08), transparent 25%),
        radial-gradient(circle at bottom right, rgba(15,23,42,.08), transparent 30%),
        var(--bg);
    }
    .wrap { max-width: 1180px; margin: 0 auto; padding: 28px 20px 42px; }
    .hero {
      background: linear-gradient(135deg, #0f172a 0%, #17335b 55%, #0f766e 100%);
      color: #fff;
      padding: 28px 30px;
      border-radius: 24px;
      box-shadow: 0 20px 45px rgba(15,23,42,.18);
    }
    .eyebrow { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; opacity: .82; }
    h1 { margin: 10px 0 8px; font-size: 34px; line-height: 1.08; }
    .lead { max-width: 820px; font-size: 15px; line-height: 1.6; opacity: .92; }
    .layout { display: grid; grid-template-columns: 1.2fr .8fr; gap: 18px; margin-top: 18px; }
    .panel {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 22px;
      box-shadow: 0 12px 28px rgba(15,23,42,.05);
    }
    .panel h2 { margin: 0 0 12px; font-size: 21px; }
    .muted { color: var(--muted); font-size: 14px; line-height: 1.58; }
    .row2 {
      display: grid;
      grid-template-columns: 1fr 210px;
      gap: 12px;
      margin-top: 14px;
    }
    label {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 600;
    }
    input, select, textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 11px 12px;
      font-size: 14px;
      color: var(--ink);
      background: #fff;
    }
    textarea {
      min-height: 116px;
      resize: vertical;
      font-family: Consolas, Monaco, monospace;
    }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
    button {
      border: 1px solid #cbd5e1;
      background: #f8fafc;
      color: var(--ink);
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
    }
    button.primary { background: #0f172a; color: #fff; border-color: #0f172a; }
    button:hover { filter: brightness(.98); }
    .status {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.5;
      background: #f8fafc;
      border: 1px solid var(--line);
      color: var(--muted);
    }
    .status.good { background: #ecfdf3; border-color: #ccebd8; color: var(--good); }
    .status.warn { background: #fff7ed; border-color: #fed7aa; color: var(--warn); }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 14px;
    }
    th, td {
      padding: 10px 8px;
      border-bottom: 1px solid #e8edf3;
      text-align: left;
      font-size: 14px;
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }
    .pillbar { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .pill {
      display: inline-flex;
      align-items: center;
      padding: 7px 10px;
      border-radius: 999px;
      background: #eff6ff;
      color: #1d4ed8;
      border: 1px solid #bfdbfe;
      font-size: 12px;
      font-weight: 700;
    }
    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .row2 { grid-template-columns: 1fr; }
      h1 { font-size: 28px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div class="eyebrow">Power Platform Governance</div>
      <h1>Report Subscriptions</h1>
      <div class="lead">
        Centro de control operativo para definir desde la app quién recibe el informe del flujo y qué contenido recibe.
        La persistencia se realiza sobre la variable de entorno <code>kyn_Notificacincorreosinformesflujo</code>.
      </div>
    </section>

    <section class="layout">
      <article class="panel">
        <h2>Subscription Builder</h2>
        <div class="muted">
          Cada entrada sigue el formato <code>correo|MODO</code>. El flujo soporta <code>ALL</code>,
          <code>CREATED_ONLY</code>, <code>CREATED_NON_SYSTEM</code>, <code>CHANGES_ONLY</code> y <code>NONE/OFF</code>.
        </div>
        <div class="pillbar">
          <span class="pill">ALL</span>
          <span class="pill">CREATED_ONLY</span>
          <span class="pill">CREATED_NON_SYSTEM</span>
          <span class="pill">CHANGES_ONLY</span>
          <span class="pill">NONE / OFF</span>
        </div>

        <div class="row2">
          <div>
            <label for="recipientEmail">Correo</label>
            <input id="recipientEmail" placeholder="usuario@empresa.com">
          </div>
          <div>
            <label for="reportMode">Modo</label>
            <select id="reportMode">
              <option value="ALL">ALL</option>
              <option value="CREATED_ONLY">CREATED_ONLY</option>
              <option value="CREATED_NON_SYSTEM">CREATED_NON_SYSTEM</option>
              <option value="CHANGES_ONLY">CHANGES_ONLY</option>
              <option value="NONE">NONE</option>
              <option value="OFF">OFF</option>
            </select>
          </div>
        </div>

        <div class="actions">
          <button onclick="addRow()">Agregar</button>
          <button onclick="clearRows()">Limpiar</button>
          <button onclick="loadSubscriptions()">Recargar</button>
          <button class="primary" onclick="saveSubscriptions()">Guardar en Dataverse</button>
        </div>

        <div id="statusBox" class="status">Cargando configuracion...</div>

        <div style="margin-top:14px;">
          <label for="rawConfig">Valor persistido</label>
          <textarea id="rawConfig" placeholder="ana@empresa.com|ALL;ops@empresa.com|CHANGES_ONLY"></textarea>
        </div>
      </article>

      <article class="panel">
        <h2>Current Entries</h2>
        <div class="muted">
          Esta vista descompone el valor actual para revisión rápida. Si un usuario no debe recibir nada, usa <code>NONE</code>
          o <code>OFF</code>.
        </div>
        <table>
          <thead>
            <tr>
              <th>Email</th>
              <th>Mode</th>
            </tr>
          </thead>
          <tbody id="subsTable">
            <tr><td colspan="2" class="muted">Sin datos.</td></tr>
          </tbody>
        </table>
      </article>
    </section>
  </div>

  <script>
    var schemaName = "kyn_Notificacincorreosinformesflujo";
    var currentDefinitionId = null;
    var currentValueId = null;

    function getXrm() {
      if (window.parent && window.parent.Xrm) return window.parent.Xrm;
      if (window.Xrm) return window.Xrm;
      return null;
    }

    function setStatus(message, kind) {
      var box = document.getElementById("statusBox");
      box.className = "status" + (kind ? " " + kind : "");
      box.textContent = message;
    }

    function normalizeEntries(raw) {
      return raw
        .split(";")
        .map(function (x) { return x.trim(); })
        .filter(Boolean);
    }

    function renderTable(raw) {
      var rows = normalizeEntries(raw);
      var tbody = document.getElementById("subsTable");
      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="2" class="muted">Sin datos.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map(function (entry) {
        var parts = entry.split("|");
        var mail = (parts[0] || "").trim();
        var mode = (parts[1] || "ALL").trim().toUpperCase();
        return "<tr><td>" + escapeHtml(mail) + "</td><td>" + escapeHtml(mode) + "</td></tr>";
      }).join("");
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function addRow() {
      var email = (document.getElementById("recipientEmail").value || "").trim();
      var mode = (document.getElementById("reportMode").value || "ALL").trim();
      if (!email || email.indexOf("@") === -1) {
        setStatus("Introduce un correo valido antes de agregar.", "warn");
        return;
      }
      var raw = document.getElementById("rawConfig");
      var next = email + "|" + mode;
      raw.value = raw.value.trim() ? raw.value.trim() + ";" + next : next;
      document.getElementById("recipientEmail").value = "";
      renderTable(raw.value);
      setStatus("Entrada agregada. Guarda para persistir en Dataverse.", "good");
    }

    function clearRows() {
      document.getElementById("rawConfig").value = "";
      renderTable("");
      setStatus("Configuracion limpiada en pantalla. Guarda para persistir.", "warn");
    }

    async function loadSubscriptions() {
      var xrm = getXrm();
      if (!xrm || !xrm.WebApi) {
        setStatus("No se ha encontrado contexto Xrm. Abre esta pagina desde la model-driven app.", "warn");
        return;
      }
      setStatus("Cargando configuracion desde Dataverse...");
      currentDefinitionId = null;
      currentValueId = null;

      try {
        var defResult = await xrm.WebApi.retrieveMultipleRecords(
          "environmentvariabledefinition",
          "?$select=environmentvariabledefinitionid,defaultvalue,schemaname&$filter=schemaname eq '" + schemaName + "'"
        );
        if (!defResult.entities.length) {
          setStatus("No se encontro la variable de entorno " + schemaName + ".", "warn");
          return;
        }

        var def = defResult.entities[0];
        currentDefinitionId = def.environmentvariabledefinitionid;

        var valResult = await xrm.WebApi.retrieveMultipleRecords(
          "environmentvariablevalue",
          "?$select=environmentvariablevalueid,value&$filter=_environmentvariabledefinitionid_value eq " + currentDefinitionId
        );

        var raw = "";
        if (valResult.entities.length) {
          currentValueId = valResult.entities[0].environmentvariablevalueid;
          raw = valResult.entities[0].value || "";
        } else {
          raw = def.defaultvalue || "";
        }

        document.getElementById("rawConfig").value = raw;
        renderTable(raw);
        setStatus("Configuracion cargada correctamente.", "good");
      } catch (error) {
        setStatus("No se pudo leer la configuracion. Revisa permisos sobre Environment Variables. " + (error.message || ""), "warn");
      }
    }

    async function saveSubscriptions() {
      var xrm = getXrm();
      if (!xrm || !xrm.WebApi) {
        setStatus("No se ha encontrado contexto Xrm. Abre esta pagina desde la model-driven app.", "warn");
        return;
      }
      if (!currentDefinitionId) {
        setStatus("No hay definitionId cargado. Recarga antes de guardar.", "warn");
        return;
      }

      var raw = (document.getElementById("rawConfig").value || "").trim();
      try {
        if (currentValueId) {
          await xrm.WebApi.updateRecord("environmentvariablevalue", currentValueId, { value: raw });
        } else {
          await xrm.WebApi.createRecord("environmentvariablevalue", {
            value: raw,
            "environmentvariabledefinitionid@odata.bind": "/environmentvariabledefinitions(" + currentDefinitionId + ")"
          });
        }
        renderTable(raw);
        setStatus("Configuracion guardada correctamente en Dataverse.", "good");
        await loadSubscriptions();
      } catch (error) {
        setStatus("No se pudo guardar la configuracion. Revisa permisos de escritura sobre Environment Variables. " + (error.message || ""), "warn");
      }
    }

    document.getElementById("rawConfig").addEventListener("input", function (e) {
      renderTable(e.target.value || "");
    });

    loadSubscriptions();
  </script>
</body>
</html>
