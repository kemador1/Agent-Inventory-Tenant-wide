var KYNAgentModelIcon = (function () {
  "use strict";

  var WEB_RESOURCE_NAME = "kyn_agent_model_icon_host_html";
  var TARGET_CONTROL_NAME = "WebResource_ModelIcon";
  var MODEL_JSON_FIELD = "kyn_modeljson";
  var MODEL_PROVIDER_FIELD = "kyn_modelprovider";
  var FALLBACK_PROVIDER = "Sin clasificar";
  var FALLBACK_MODEL = "No se ha identificado un modelo conocido.";

  var iconMap = {
    openai: "kyn_chatgpt_icon",
    anthropic: "kyn_claude_ai_icon",
    microsoft: "kyn_copilot_icon"
  };

  function normalizeText(value) {
    return (value || "").toString().trim();
  }

  function normalizeKey(value) {
    return normalizeText(value).toLowerCase();
  }

  function tryParseJson(raw) {
    if (!raw || typeof raw !== "string") {
      return null;
    }
    try {
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function firstNonEmpty(values) {
    for (var i = 0; i < values.length; i += 1) {
      var value = normalizeText(values[i]);
      if (value) {
        return value;
      }
    }
    return "";
  }

  function detectFromText(rawText) {
    var text = normalizeKey(rawText);
    if (!text) {
      return { provider: "", model: "" };
    }

    if (text.indexOf("claude") > -1 || text.indexOf("anthropic") > -1) {
      return { provider: "Anthropic", model: normalizeText(rawText) };
    }
    if (text.indexOf("gpt") > -1 || text.indexOf("openai") > -1 || text.indexOf("chatgpt") > -1) {
      return { provider: "OpenAI", model: normalizeText(rawText) };
    }
    if (text.indexOf("copilot") > -1 || text.indexOf("microsoft") > -1) {
      return { provider: "Microsoft", model: normalizeText(rawText) };
    }
    if (text.indexOf("gemini") > -1 || text.indexOf("google") > -1) {
      return { provider: "Google", model: normalizeText(rawText) };
    }
    if (text.indexOf("llama") > -1 || text.indexOf("meta") > -1) {
      return { provider: "Meta", model: normalizeText(rawText) };
    }
    return { provider: "", model: normalizeText(rawText) };
  }

  function resolveModelInfo(formContext) {
    var providerValue = getAttributeValue(formContext, MODEL_PROVIDER_FIELD);
    var modelJsonValue = getAttributeValue(formContext, MODEL_JSON_FIELD);
    var parsed = tryParseJson(modelJsonValue);

    var rawModel =
      firstNonEmpty([
        parsed && parsed.displayName,
        parsed && parsed.name,
        parsed && parsed.model,
        parsed && parsed.modelName,
        parsed && parsed.providerModel,
        modelJsonValue
      ]) || "";

    var detected = detectFromText(rawModel || providerValue);
    var provider = normalizeText(providerValue) || detected.provider || FALLBACK_PROVIDER;
    var model = rawModel || detected.model || FALLBACK_MODEL;
    var icon = iconMap[normalizeKey(provider)] || "";

    return {
      provider: provider,
      model: model,
      icon: icon
    };
  }

  function getAttributeValue(formContext, fieldName) {
    var attribute = formContext.getAttribute(fieldName);
    if (!attribute) {
      return "";
    }
    return attribute.getValue();
  }

  function getTargetControl(formContext) {
    return formContext.getControl(TARGET_CONTROL_NAME);
  }

  function buildUrl(modelInfo) {
    var query =
      "?provider=" + encodeURIComponent(modelInfo.provider) +
      "&model=" + encodeURIComponent(modelInfo.model) +
      "&icon=" + encodeURIComponent(modelInfo.icon);
    return WEB_RESOURCE_NAME + query;
  }

  function refreshIcon(executionContext) {
    var formContext = executionContext.getFormContext();
    var control = getTargetControl(formContext);

    if (!control || typeof control.setSrc !== "function") {
      return;
    }

    control.setSrc(buildUrl(resolveModelInfo(formContext)));
  }

  return {
    refreshIcon: refreshIcon
  };
})();
